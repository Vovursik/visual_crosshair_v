{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "visual-crosshair-v",
  "version": "0.2.0",
  "identifier": "com.vovasik.visual-crosshair",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [{
        "title": "",
        "width": 200,
        "height": 200,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false,
        "resizable": false
      }],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
